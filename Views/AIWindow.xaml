<Window x:Class="BimAiAssistant.Views.AIWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI Assistant"
        Width="620"
        Height="720"
        MinWidth="520"
        MinHeight="560"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="MinWidth" Value="92" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Background" Value="#2563EB" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="FontSize" Value="14" />
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,14">
            <TextBlock Text="AI Assistant" FontSize="24" FontWeight="SemiBold" Foreground="#111827" />
            <TextBlock Text="{Binding Settings.ApiUrl}" Foreground="#64748B" Margin="0,4,0,0" />
        </StackPanel>

        <Border Grid.Row="1" BorderBrush="#E2E8F0" BorderThickness="1" Background="White">
            <ListBox ItemsSource="{Binding Messages}"
                     BorderThickness="0"
                     Padding="12"
                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,10" Padding="12" BorderBrush="#E5E7EB" BorderThickness="1" Background="#FFFFFF">
                            <StackPanel>
                                <TextBlock Text="{Binding Author}" FontWeight="SemiBold" Foreground="#334155" />
                                <TextBlock Text="{Binding Text}" TextWrapping="Wrap" Margin="0,6,0,0" Foreground="#111827" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <Grid Grid.Row="2" Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox Text="{Binding Message, UpdateSourceTrigger=PropertyChanged}"
                     MinHeight="44"
                     VerticalContentAlignment="Center"
                     ToolTip="Message" />
            <Button Grid.Column="1"
                    Margin="10,0,0,0"
                    Content="Send"
                    Command="{Binding SendCommand}" />
        </Grid>
    </Grid>
</Window>
