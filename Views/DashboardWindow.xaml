<Window x:Class="BimAiAssistant.Views.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Maybeworks Dashboard"
        Width="760"
        Height="620"
        MinWidth="620"
        MinHeight="520"
        WindowStartupLocation="CenterScreen"
        Background="#F8FAFC">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#0F172A" />
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Maybeworks BIM Dashboard" FontSize="26" FontWeight="SemiBold" />
            <TextBlock Text="{Binding Project}" Margin="0,4,0,0" Foreground="#64748B" />
        </StackPanel>

        <ItemsControl Grid.Row="1" ItemsSource="{Binding Metrics}" Margin="0,22,0,20">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="3" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,0,12,12" Padding="16" BorderBrush="#E2E8F0" BorderThickness="1" Background="White">
                        <StackPanel>
                            <TextBlock Text="{Binding Name}" Foreground="#64748B" FontSize="13" />
                            <TextBlock Text="{Binding Value}" FontSize="28" FontWeight="SemiBold" Margin="0,6,0,0" />
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Border Grid.Row="2" BorderBrush="#E2E8F0" BorderThickness="1" Background="White" Padding="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Text="Model Metrics" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,14" />

                <ItemsControl Grid.Row="1" ItemsSource="{Binding Metrics}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="64" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center" Foreground="#334155" />
                                <Grid Grid.Column="1" Height="18" VerticalAlignment="Center">
                                    <Border Background="#E2E8F0" />
                                    <Border HorizontalAlignment="Left" Background="{Binding Color}" Width="{Binding BarWidth}" MinWidth="6" />
                                </Grid>
                                <TextBlock Grid.Column="2" Text="{Binding Value}" HorizontalAlignment="Right" VerticalAlignment="Center" FontWeight="SemiBold" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Border>
    </Grid>
</Window>
